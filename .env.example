# PowerDNS API key (used by both pdns and poweradmin)
PDNS_API_KEY=changeme

# Secret key for session signing (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=change-this-to-a-random-secret

# Default admin password (only used on first run)
ADMIN_PASSWORD=admin

# Port to expose PowerAdmin on
POWERADMIN_PORT=8080
